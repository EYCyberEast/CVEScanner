# ─── CVEScan Pro Web Edition — environment configuration ───
# Copy this file to ".env" and fill in your values. NEVER commit .env.

# ════════ AI PROVIDERS ════════
# Set the API key for ANY ONE (or more) of the providers below.
# The tool auto-detects whichever key(s) you supply. If you configure
# several, AI_PROVIDER picks the default and you can switch in the UI.

# Which provider to use by default: gemini | openai | anthropic | groq
# Leave blank to auto-select the first configured one.
AI_PROVIDER=

# --- Google Gemini ---  key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (GPT) ---   key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Anthropic (Claude) ---  key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Groq (fast Llama inference) ---  key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ════════ CVE DATA SOURCES ════════
# NVD API key — free, strongly recommended (removes the slow rate limit).
# Get one at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# GitHub token — optional, raises the GitHub Advisory rate limit.
GITHUB_TOKEN=

# ════════ STORAGE ════════
# Optional: where to store the watchlist + CVE cache (defaults to ./data).
# On ephemeral hosts use a persistent disk path.
# CVESCAN_DATA_DIR=/var/data/cvescan

# Set to 1 only for local debugging.
FLASK_DEBUG=
